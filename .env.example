# Application
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=9203106
DB_DATABASE=cps_database
DB_SCHEMA=iam
DB_SYNCHRONIZE=false

# JWT Configuration
JWT_ACCESS_SECRET=your-jwt-access-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_DEPARTMENT_SELECTION_SECRET=your-department-selection-secret-key-change-in-production
JWT_DEPARTMENT_SELECTION_EXPIRES_IN=5m

# Security Configuration
PASSWORD_HASH_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# Initial Super Admin
INITIAL_SUPER_ADMIN_USERNAME=superadmin
INITIAL_SUPER_ADMIN_PASSWORD=change-me-secure-password
INITIAL_SUPER_ADMIN_FIRST_NAME=System
INITIAL_SUPER_ADMIN_LAST_NAME=Administrator
INITIAL_SUPER_ADMIN_EMAIL=superadmin@example.com
